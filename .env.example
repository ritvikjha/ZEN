# Discord Bot Token (REQUIRED)
DISCORD_TOKEN=your_bot_token_here

# Bot Prefix (Optional, defaults to 'Z')
PREFIX=Z

# Owner ID (Optional)
OWNER_ID=123456789012345678

# Starting Balance for new users (Optional, defaults to 5000)
STARTING_BALANCE=5000

# MongoDB URI (Optional but highly recommended for Docker)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/zenbot?retryWrites=true&w=majority
