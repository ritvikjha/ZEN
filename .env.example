# ═══════════════════════════════════════════════════════════════════
#  ZEN Bot — Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ── Discord ───────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
OWNER_ID=0
PREFIX=Z
STARTING_BALANCE=5000

# ── Database ──────────────────────────────────────────────────────
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/zenbot

# ── AI ────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Instagram Auto-Embed ─────────────────────────────────────────
# Master toggle (true/false)
INSTAGRAM_ENABLED=true

# Temporary download directory (auto-cleaned)
INSTAGRAM_TEMP_FOLDER=./data/temp_instagram

# Max file size for Discord uploads (bytes). Default: 25 MB
INSTAGRAM_MAX_FILE_SIZE=25000000

# Download timeout in seconds
INSTAGRAM_TIMEOUT=30

# Number of concurrent download workers
INSTAGRAM_MAX_WORKERS=3

# Rate limiting: per-user cooldown (seconds)
INSTAGRAM_USER_COOLDOWN=10

# Rate limiting: per-guild cooldown (seconds)
INSTAGRAM_GUILD_COOLDOWN=5

# Display: send text embed alongside video (true/false, default: false for clean video only)
INSTAGRAM_SHOW_EMBED=false

# Logging level: DEBUG, INFO, WARNING, ERROR
INSTAGRAM_LOG_LEVEL=INFO
